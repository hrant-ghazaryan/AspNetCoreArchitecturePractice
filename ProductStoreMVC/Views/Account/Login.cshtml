<h2>Login</h2>

<form asp-action="Login" method="post">

    <div>
        <label>User Name</label>
        <input name="userName" />
    </div>

    <div>
        <label>Password</label>
        <input name="password" type="password" />
    </div>

    <button type="submit">Login</button>

</form>
