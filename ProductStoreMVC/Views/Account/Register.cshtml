@model ProductStoreMVC.Models.User

<h2>Register</h2>

<form asp-action="Register" method="post">

    <div>
        <label>Name</label>
        <input asp-for="Name" />
    </div>

    <div>
        <label>Email</label>
        <input asp-for="Email" />
    </div>

    <div>
        <label>Password</label>
        <input asp-for="PasswordHesh" type="password" />
    </div>

    <button type="submit">Register</button>

</form>
