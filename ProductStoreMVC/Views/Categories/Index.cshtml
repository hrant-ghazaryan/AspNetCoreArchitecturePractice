@model List<ProductStoreMVC.Models.Category>

<h2>Categories</h2>

<!-- 🔴 Create button միայն Admin-ին -->
@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">
        Create
    </a>
}

<table class="table table-bordered">

    <thead>
        <tr>
            <!-- 🔴 Id միայն Admin -->
            @if (User.IsInRole("Admin"))
            {
                <th>Id</th>
            }

            <th>Name</th>

            <!-- 🔴 Actions միայն Admin -->
            @if (User.IsInRole("Admin"))
            {
                <th>Actions</th>
            }
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <!-- 🔴 Id միայն Admin -->
                @if (User.IsInRole("Admin"))
                    { <td>@item.Id</td> }

                <!-- 🟢 User + Guest + Admin բոլորը տեսնում են Name -->
                <td>@item.Name</td>

                <!-- 🔴 Actions միայն Admin -->
                @if (User.IsInRole("Admin"))
                {
                    <td>
                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>
                    </td>
                }

            </tr>
        }

    </tbody>

</table>