@model List<ProductStoreMVC.Models.Category>

<h2>Categories</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    Create
</a>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>
                    <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger">
                        Delete
                    </a>
                    <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning">
                        Edit
                    </a>
                </td>
            </tr>
        }

    </tbody>

</table>
