@model ProductStoreMVC.Models.Category

<h2>Edit Category</h2>

<form asp-action="EditConfirmed"
      asp-route-id="@Model.Id"
      method="post">

    <div asp-validation-summary="All"
         class="text-danger">
    </div>

    <div class="mb-3">

        <label asp-for="Name"></label>

        <input asp-for="Name"
               class="form-control" />

        <span asp-validation-for="Name"
              class="text-danger">
        </span>

    </div>

    <button type="submit"
            class="btn btn-warning">
        Save
    </button>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}