@model ProductStoreMVC.Models.Category

<h2>Create Category</h2>

<form asp-action="Create" method="post">

    @* <!-- Բոլոր validation errors-ների ցուցադրում -->
    <div asp-validation-summary="All"
         class="text-danger">
    </div> *@

    <div class="mb-3">

        <!-- Label -->
        <label asp-for="Name"></label>

        <!-- Input -->
        <input asp-for="Name"
               class="form-control" />

        <!-- Name property-ի validation message -->
        <span asp-validation-for="Name"
              class="text-danger">
        </span>

    </div>

    <button type="submit"
            class="btn btn-primary">
        Save
    </button>

</form>

